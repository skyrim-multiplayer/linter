{
  "name": "@skyrim-multiplayer/linter",
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "skymp-linter": "dist/linter.mjs"
  },
  "scripts": {
    "postinstall": "mkdir -p .linter && curl -fsSL https://raw.githubusercontent.com/skyrim-multiplayer/linter/main/dist/linter.mjs -o .linter/linter.mjs",
    "build": "node esbuild.config.js",
    "lint": "node .linter/linter.mjs --lint",
    "fix": "node .linter/linter.mjs --fix",
    "update-linter": "cp dist/linter.mjs .linter/linter.mjs"
  },
  "dependencies": {
    "express": "^5.2.1",
    "morgan": "^1.10.1",
    "p-limit": "^7.3.0",
    "simple-git": "^3.27.0",
    "tsscmp": "^1.0.6"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "typescript": "^6.0.2"
  }
}
